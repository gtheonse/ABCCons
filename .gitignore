## Ignore Visual Studio temporary files, build results, and
## files generated by dotnet/Visual Studio.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates
*.userprefs

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Re]leases/
x64/
x86/
[AR]M/
[AR]M64/
bld/
[Bb]in/
[Oo]bj/
[Log]s/

# Visual Studio cache and work directories
.vs/
.vscode/

# User secrets and local settings
local.settings.json

# OS-generated files
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store
